{
  "expo": {
    "name": "Represent Wallet",
    "slug": "represent-wallet",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "represent",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#040707"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.representwallet.app",
      "buildNumber": "3",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Represent uses your camera to verify your identity through our partner Veriff.",
        "NSFaceIDUsageDescription": "Represent uses Face ID to securely sign you in to your verified civic account.",
        "NSMicrophoneUsageDescription": "Represent uses your microphone during identity verification recordings.",
        "NSPhotoLibraryUsageDescription": "Represent needs access to your photo library to attach images to proposals.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.945878560232-blus90hj4nqh6h32msts24971t72f8g7"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#040707"
      },
      "package": "com.representwallet.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      "@react-native-google-signin/google-signin",
      "expo-image-picker",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.representwallet.app",
          "enableGooglePay": true
        }
      ],
      "react-native-iap"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "60aaafa2-14de-4863-90e2-c972babf0fe1"
      }
    },
    "owner": "lstar977"
  }
}