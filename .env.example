# Represent Wallet Mobile App - Environment Variables
# Copy this file to .env and fill in your values

# API Configuration
EXPO_PUBLIC_API_URL=https://representportal.com

# Stripe Configuration
# Get your publishable key from https://dashboard.stripe.com/apikeys
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Google OAuth Configuration (for Google Sign-In)
# Get credentials from https://console.cloud.google.com/apis/credentials
# Note: These are currently hardcoded in app/index.tsx and should be moved here
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_client_id.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com
